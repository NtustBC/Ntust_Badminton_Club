rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isBootstrapAdminEmail() {
      return isSignedIn() && request.auth.token.email == "admin@gmail.com";
    }

    function isAdmin() {
      return isBootstrapAdminEmail() || (
        isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isBootstrapAdminEmail() && request.auth.uid == userId;
      allow update, delete: if false;
    }

    match /members/{userId} {
      allow get: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow list: if isAdmin();
      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    match /applications/{applicationId} {
      allow create: if true;
      allow get, list: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /signupApprovals/{emailId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /classSessions/{sessionId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /classSessionSignups/{signupId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.sessionId is string;
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /classAnnouncements/{announcementId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
